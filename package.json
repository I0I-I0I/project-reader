{
    "name": "project-reader",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "lint": "oxfmt --check . && oxlint .",
        "format": "oxfmt --write ."
    },
    "dependencies": {
        "pdfjs-dist": "^4.10.38"
    },
    "devDependencies": {
        "@inlang/paraglide-js": "^2.15.2",
        "@sveltejs/adapter-auto": "^7.0.1",
        "@sveltejs/kit": "^2.57.0",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@types/node": "^22",
        "oxfmt": "^0.51.0",
        "oxlint": "^1.66.0",
        "svelte": "^5.55.2",
        "svelte-check": "^4.4.6",
        "typescript": "^6.0.2",
        "vite": "^8.0.7"
    }
}
