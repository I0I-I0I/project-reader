{
    "name": "project-reader",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "prepare": "svelte-kit sync || echo ''",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && pnpm check:boundaries",
        "check:boundaries": "node scripts/check-module-boundaries.mjs",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "lint": "oxfmt --check . && oxlint .",
        "format": "oxfmt --write ."
    },
    "dependencies": {
        "dexie": "^4.4.4",
        "fuse.js": "^7.5.0",
        "p-limit": "^7.3.0",
        "pdfjs-dist": "^4.10.38"
    },
    "devDependencies": {
        "@csstools/postcss-global-data": "^4.0.0",
        "@inlang/paraglide-js": "^2.15.2",
        "@sveltejs/adapter-node": "^5.5.4",
        "@sveltejs/adapter-static": "^3.0.10",
        "@sveltejs/kit": "^2.57.0",
        "@sveltejs/mcp": "^0.1.24",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@types/node": "^22",
        "@vitejs/plugin-basic-ssl": "^2.3.0",
        "oxfmt": "^0.51.0",
        "oxlint": "^1.66.0",
        "postcss": "^8.5.15",
        "postcss-custom-media": "^12.0.1",
        "svelte": "^5.55.2",
        "svelte-check": "^4.4.6",
        "typescript": "^6.0.2",
        "vite": "^8.0.7",
        "vitest": "^4.1.10"
    },
    "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a"
}
